<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BuildByGod" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/ink</item>
        <item name="android:statusBarColor">@color/ink</item>
        <item name="android:navigationBarColor">@color/ink</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.BuildByGod.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ink</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.BuildByGod</item>
    </style>
</resources>
